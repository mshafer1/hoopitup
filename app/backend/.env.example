# Backend Configuration
# Copy this file to .env and fill in the values for your environment

# Flask secret key for sessions and CSRF protection (use a strong random string in production)
SECRET_KEY=your-secret-key-here-change-in-production

# Domain name for the application
DOMAIN_NAME=localhost

# Flask environment (development or production)
FLASK_ENV=production

# Debug mode (set to False in production)
DEBUG=False

# CORS allowed origins (comma-separated or use * for all)
CORS_ALLOWED_ORIGINS=*

# ============================================================================
# Scheduled Message Configuration
# ============================================================================

# Cron expression for when to send the scheduled message
# Format: minute hour day month day_of_week
# Default: 0 7 * * 2,4 (7 AM on Tuesday and Thursday)
# Examples:
#   0 7 * * 1-5    = 7 AM Monday to Friday
#   0 9,14 * * *   = 9 AM and 2 PM every day
#   30 18 * * 5    = 6:30 PM on Friday
SCHEDULE_CRON=0 7 * * 2,4

# Message to broadcast at the scheduled time
SCHEDULE_MESSAGE=Game today @ 4:30?

# Timezone for the cron schedule (IANA timezone format)
# Common options: UTC, America/New_York, America/Chicago, America/Los_Angeles, etc.
SCHEDULE_TIMEZONE=UTC

# Daily summary time (HH:MM) to send a summary every day
# Example: 16:00 for 4 PM daily
SCHEDULE_SUMMARY_TIME=16:00
