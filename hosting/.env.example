# Hoop It Up Application Environment Configuration
# Copy this file to .env and update the values for your environment

# ============================================================================
# Flask Backend Configuration
# ============================================================================

# Secret key for Flask sessions and CSRF protection
# Generate a strong random key for production
# Example: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-here-change-in-production

# Domain name where the application will be hosted
# Used for CORS configuration and frontend URLs
DOMAIN_NAME=localhost

# Flask environment (development or production)
FLASK_ENV=production

# Enable debug mode (should be False in production)
DEBUG=False

# CORS allowed origins
# Use * to allow all origins (not recommended for production)
# Or specify comma-separated list: https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=*

# ============================================================================
# Scheduled Message Configuration
# ============================================================================

# Cron expression for when to send the scheduled message
# Format: minute hour day month day_of_week
# Default: 0 7 * * 2,4 (7 AM on Tuesday and Thursday)
# Examples:
#   0 7 * * 1-5    = 7 AM Monday to Friday
#   0 9,14 * * *   = 9 AM and 2 PM every day
#   30 18 * * 5    = 6:30 PM on Friday
SCHEDULE_CRON=0 7 * * 2,4

# Message to broadcast at the scheduled time
SCHEDULE_MESSAGE=Game today @ 4:30?

# Timezone for the cron schedule (IANA timezone format)
# Common options: UTC, America/New_York, America/Chicago, America/Los_Angeles, etc.
SCHEDULE_TIMEZONE=UTC

# Daily summary time (HH:MM) to send a summary every day
# Example: 12:00 for noon daily
SCHEDULE_SUMMARY_TIME=12:00

# ============================================================================
# Application Runtime
# ============================================================================

# Number of uWSGI worker processes
# Default: 4 (set in uwsgi.ini)
# UWSGI_PROCESSES=4

# Number of threads per uWSGI worker
# Default: 2 (set in uwsgi.ini)
# UWSGI_THREADS=2
